# ── Servidor ──────────────────────────────
PORT=4000
NODE_ENV=development

# ── MySQL ─────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=cursomate

# ── JWT ───────────────────────────────────
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_en_produccion
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────
# URL de tu frontend Next.js (sin trailing slash)
CORS_ORIGIN=http://localhost:3000
