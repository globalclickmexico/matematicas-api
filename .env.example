# ── Servidor ──────────────────────────────
PORT=4000
NODE_ENV=development

# ── MySQL ─────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=cursomate

# ── JWT ───────────────────────────────────
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_en_produccion
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────
# URL de tu frontend Next.js (sin trailing slash)
CORS_ORIGIN=http://localhost:3000

# ── Email / SMTP ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password
EMAIL_FROM="CursoMate <noreply@cursomate.mx>"

# ── Frontend ───────────────────────────────
FRONTEND_URL=http://localhost:3000
